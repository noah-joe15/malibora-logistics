      "url": "/?shortcut=log-trip&source=pwa",
      "icons": [
        {
          "src": "icons/shortcut-trip.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Log Expense",
      "short_name": "Expense",
      "description": "Record fuel, driver allowance or mechanic expense",
      "url": "/?shortcut=log-expense&source=pwa",
      "icons": [
        {
          "src": "icons/shortcut-expense.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Live Map",
      "short_name": "Map",
      "description": "View real-time fleet route tracking across Tanzania",
      "url": "/?shortcut=map&source=pwa",
      "icons": [
        {
          "src": "icons/shortcut-map.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Compliance",
      "short_name": "Permits",
      "description": "Check permit expiry dates and regulatory status",
      "url": "/?shortcut=compliance&source=pwa",
      "icons": [
        {
          "src": "icons/shortcut-compliance.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    }
  ],

  "share_target": {
    "action": "/?action=share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "files": [
        {
          "name": "receipt",
          "accept": ["image/png", "image/jpeg", "image/jpg", "application/pdf"]
        }
      ]
    }
  },

  "protocol_handlers": [
    {
      "protocol": "web+malibora",
      "url": "/?protocol=%s"
    }
  ],

  "prefer_related_applications": false,
  "related_applications": [],

  "edge_side_panel": {
    "preferred_width": 400
  }
