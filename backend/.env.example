# ── API SECURITY ────────────────────────────────────────────
API_KEY=MALIBORA_SECRET_KEY_2026

# ── DATABASE (Supabase) ─────────────────────────────────────
DATABASE_URL=postgresql://postgres.yzvjutqqujbpvalelbld:YOUR_PASSWORD@aws-1-eu-central-1.pooler.supabase.com:5432/postgres

# ── AFRICA'S TALKING ────────────────────────────────────────
AT_USERNAME=sandbox
AT_API_KEY=your_africastalking_api_key_here
AT_SENDER_ID=MALIBORA

# ── APP CONFIG ──────────────────────────────────────────────
APP_ENV=production
DEBUG=false
ALLOWED_ORIGINS=https://your-frontend-domain.com

# ── JWT (for future token auth) ─────────────────────────────
JWT_SECRET=replace_with_a_long_random_string_at_least_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
